{
  "name": "@rgm-power-tools/server",
  "version": "0.1.0",
  "description": "Self-hostable dashboard and JSON API to drive the RGM Power Tools",
  "license": "MIT",
  "type": "module",
  "bin": {
    "monitor-dashboard": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "public"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "dev": "node --import tsx src/cli.ts"
  },
  "dependencies": {
    "@rgm-power-tools/core": "workspace:*",
    "@rgm-power-tools/monitor-config": "workspace:*",
    "@rgm-power-tools/monitor-tagger": "workspace:*",
    "@rgm-power-tools/monitor-doctor": "workspace:*",
    "@rgm-power-tools/monitor-replay": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
